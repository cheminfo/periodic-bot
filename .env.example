# Telegram Bot API token issued by BotFather (https://t.me/BotFather).
TELEGRAM_TOKEN=

# GitHub Personal Access Token — only required on deploy hosts that need to
# pull the Docker image from ghcr.io when the package is private.
# Create at https://github.com/settings/tokens with the `read:packages` scope
# (classic token) or `packages: read` (fine-grained), then run once:
#   echo "$GHCR_TOKEN" | docker login ghcr.io -u <your-github-username> --password-stdin
# Leave empty if the ghcr.io package is public.
GHCR_TOKEN=
