{
  "name": "periodic-bot",
  "version": "1.0.1",
  "description": "Telegram bot that provides information about periodic table elements.",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "files": [
    "src"
  ],
  "keywords": [
    "periodic",
    "table",
    "chemistry",
    "telegram",
    "bot"
  ],
  "author": "Miguel Asencio <maasencioh@gmail.com> (https://github.com/maasencioh)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cheminfo/periodic-bot.git"
  },
  "bugs": {
    "url": "https://github.com/cheminfo/periodic-bot/issues"
  },
  "homepage": "https://github.com/cheminfo/periodic-bot#readme",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env --watch src/index.js",
    "eslint": "eslint src",
    "eslint-fix": "npm run eslint -- --fix",
    "prettier": "prettier --check src",
    "prettier-write": "prettier --write src",
    "start": "node --env-file-if-exists=.env src/index.js",
    "test": "npm run test-only && npm run eslint && npm run prettier",
    "test-only": "vitest run"
  },
  "dependencies": {
    "fuse.js": "^7.3.0",
    "mf-parser": "^3.9.0",
    "node-telegram-bot-api": "^0.67.0"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-cheminfo": "^18.0.0",
    "prettier": "^3.8.3",
    "vitest": "^4.1.4"
  }
}
